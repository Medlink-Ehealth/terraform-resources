# ─────────────────────────────────────────────────────────────────────────────
# environments/dev/terraform.tfvars.example
#
# COPY THIS FILE → terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored and will NEVER be pushed to GitHub.
#
# HOW TO FIND THESE VALUES:
#   subscription_id → az account show --query id -o tsv
#   tenant_id       → az account show --query tenantId -o tsv
#   client_id       → output from: az ad sp create-for-rbac ...
#   client_secret   → output from: az ad sp create-for-rbac ...
# ─────────────────────────────────────────────────────────────────────────────

# ── Change these to switch between personal and company subscriptions ─────────

subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
tenant_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
client_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
client_secret   = "your-client-secret-here"

# ── Your details ──────────────────────────────────────────────────────────────

owner = "your-email@example.com"

# ── Optional overrides (defaults already set in variables.tf) ─────────────────

# location            = "eastus2"
# environment         = "dev"
# resource_group_name = "medlink-dev-rg"
# project             = "medlink"
# cost_center         = "medlink-engineering"