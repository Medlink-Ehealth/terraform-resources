# ─────────────────────────────────────────────────────────────────────────────
# .gitignore for MedLink Terraform repository
# ─────────────────────────────────────────────────────────────────────────────

# ── NEVER commit these — they contain secrets ─────────────────────────────────
# Any root-level tfvars file a developer might create locally with credentials
*.tfvars
*.tfvars.json

# Exception: our environment tfvars files are safe — they contain NO credentials.
# Credentials come from environment variables or GitHub Secrets only.
!environments/dev.tfvars
!environments/prod.tfvars
!environments/staging.tfvars

# ── Terraform state — managed remotely via pipeline, never in git ─────────────
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform plan output files ───────────────────────────────────────────────
*.tfplan
plan.tfplan

# ── Terraform working directories ────────────────────────────────────────────
.terraform/
.terraform.lock.hcl

# ── Crash logs ────────────────────────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files ────────────────────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/